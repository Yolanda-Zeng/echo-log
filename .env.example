PORT=8787

# --- 网易云音乐 API ---
# 自部署的 NeteaseCloudMusicApi 服务地址（可选，仅影响播放音源）
# 不配置时实时获取 Deezer 真实歌曲的 30 秒试听，不使用本地模拟音频
# 专辑元数据使用 MusicBrainz + Cover Art Archive（免费，无需部署）
# Optional. Example: http://localhost:3000
NETEASE_API_BASE=

# --- 定时任务 ---
CRON_ENABLED=false

# --- 豆瓣爬虫 ---
# 豆瓣登录 Cookie（可选，携带后豆瓣限制策略为封 cookie 不封 IP）
DOUBAN_COOKIE=

# --- 管理接口 ---
# 用于 /api/admin/refresh 等管理端点的认证密钥
ADMIN_KEY=
